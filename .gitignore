__pycache__/
*.py[cod]
.pytest_cache/
.tmp-*/
tmp/
.venv/
dist/
build/
*.egg-info/

# Rebuildable indexes and transient imports
data/indexes/*
!data/indexes/.gitkeep
data/imports/*
!data/imports/.gitkeep
data/derived/*
!data/derived/.gitkeep
data/backups/*
!data/backups/.gitkeep

# Local operational logs
system/logs/*.jsonl
system/reports/generated-*
system/test-tmp*/
system/runs/*
!system/runs/.gitkeep
system/recovery/*
!system/recovery/.gitkeep

# Large/binary raw payloads stay local and require an explicit backup policy.
vault/raw/**/blobs/*
!vault/raw/**/blobs/.gitkeep
vault/raw/objects/sha256/*
!vault/raw/objects/sha256/.gitkeep
